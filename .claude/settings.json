{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(agent-browser:*)",
      "Bash(pkill -f agent-browser:*)",
      "Read(/private/tmp/*)",
      "Read(**/opensrc/**)",
      "Glob(**/opensrc/**)",
      "Read(**/node_modules/**)",
      "Glob(**/node_modules/**)",
      "mcp__figma-desktop__*",
      "mcp__ark-ui__*"
    ],
    "defaultMode": "plan"
  },
  "theme": "dark-ansi",
  "editorMode": "vim"
}
