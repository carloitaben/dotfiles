{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
    },
    "glob": {
      "/opt/homebrew/Cellar/neovim/*/share/nvim/runtime/doc": "allow",
      "/opt/homebrew/Cellar/neovim/*/share/nvim/runtime/doc/**": "allow",
    },
    "grep": {
      "/opt/homebrew/Cellar/neovim/*/share/nvim/runtime/doc": "allow",
      "/opt/homebrew/Cellar/neovim/*/share/nvim/runtime/doc/**": "allow",
    },
    "list": {
      "/opt/homebrew/Cellar/neovim/*/share/nvim/runtime/doc": "allow",
      "/opt/homebrew/Cellar/neovim/*/share/nvim/runtime/doc/**": "allow",
    },
    "external_directory": {
      "/opt/homebrew/Cellar/neovim/*/share/nvim/runtime/doc": "allow",
      "/opt/homebrew/Cellar/neovim/*/share/nvim/runtime/doc/**": "allow",
    },
    "git *": "ask",
  },
  "plugin": ["@mohak34/opencode-notifier@latest"],
  "mcp": {
    "figma": {
      "type": "local",
      "enabled": true,
      "command": [
        "node",
        "{env:HOME}/Developer/github/figma-mcp-free/packages/mcp-server/dist/index.js"
      ],
      "environment": {
        "FIGMA_TOKEN": "{env:FIGMA_TOKEN}"
      },
      "timeout": 30000
    }
  },
  }
