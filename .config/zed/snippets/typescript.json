{
  "Wait": {
    "prefix": "wait",
    "body": ["await new Promise((resolve) => setTimeout(resolve, $1))"]
  },
  "Console Dir": {
    "prefix": "dir",
    "body": ["console.dir($1, { depth: null })"]
  },
  "Effect Function": {
    "prefix": "efn",
    "body": ["Effect.fn(function* () {\n\t$0\n})"],
    "description": "Effect function"
  },
  "Effect Function (Traced)": {
    "prefix": "efnt",
    "body": ["Effect.fn(\"${0}\")(function* () {\n\t$1\n})"],
    "description": "Effect function"
  },
  "Effect Function (Untraced)": {
    "prefix": "efnu",
    "body": ["Effect.fnUntraced(function* () {\n\t$0\n})"],
    "description": "Effect function (untraced)"
  },
  "Effect Gen Function": {
    "prefix": "egen",
    "body": ["Effect.gen(function* () {\n\t$0\n})"],
    "description": "Effect generator function"
  },
  "Gen Function": {
    "prefix": "gen",
    "body": ["function* () {\n\t$0\n}"],
    "description": "Generator function"
  },
  "Effect Tagged Error": {
    "prefix": "etaggederror",
    "body": [
      "export class ${1} extends Data.TaggedError(\"${1}\")<{ readonly cause: unknown }> {}"
    ]
  },
  "Effect ServiceMap Service (Fn)": {
    "prefix": "esmf",
    "body": [
      "interface ${1:Database} {",
      "\treadonly ${2:query}: (${3:sql}: string) => ${4:string}",
      "}",
      "",
      "const ${1} = ServiceMap.Service<${1}>(\"${1}\")$0"
    ],
    "description": "ServiceMap service (fn syntax)"
  },
  "Effect ServiceMap Service (Class)": {
    "prefix": "esmc",
    "body": [
      "class ${1:Database} extends ServiceMap.Service<${1}, {",
      "\treadonly ${2:query}: (${3:sql}: string) => ${4:string}",
      "}>()(\"${1}\") {}$0"
    ],
    "description": "ServiceMap service (class syntax)"
  },
  "Effect ServiceMap Service (Class + make)": {
    "prefix": "esmcm",
    "body": [
      "class ${1:Logger} extends ServiceMap.Service<${1}>()(\"${1}\", {",
      "\tmake: Effect.gen(function* () {",
      "\t\tconst ${2:config} = yield* ${3:Config}",
      "\t\treturn { ${4:log}: (msg: string) => Effect.log(`[${2}.prefix] ${msg}`) }",
      "\t})",
      "}) {",
      "\tstatic readonly layer = Layer.effect(this, this.make).pipe(",
      "\t\tLayer.provide(${3}.layer)",
      "\t)",
      "}$0"
    ],
    "description": "ServiceMap service (class syntax, with make)"
  },
  "Effect ServiceMap Reference": {
    "prefix": "esmr",
    "body": [
      "const ${1:LogLevel} = ServiceMap.Reference<${2:\"info\" | \"warn\" | \"error\"}>(\"${1}\", {",
      "\tdefaultValue: () => ${3:\"info\" as const}",
      "})$0"
    ],
    "description": "ServiceMap reference"
  }
}
